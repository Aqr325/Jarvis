# J.A.R.V.I.S. Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true

# External LLM Configuration (Optional)
LLM_PROVIDER=openai
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o
LLM_API_KEY=your-api-key-here
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Rate Limiting
RATE_LIMIT_GENERAL=60
RATE_LIMIT_CHAT=20
RATE_LIMIT_TOOL=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/jarvis.log

# Optional: Additional API Keys for Public APIs
# (Most public APIs work without keys, but some have higher limits with keys)
# COINGECKO_API_KEY=
# OPEN_LIBRARY_API_KEY=
